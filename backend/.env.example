PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce?schema=public
JWT_SECRET=super-secret-key
FRONTEND_URL=http://localhost:5173

# Bank QR / VietQR
BANK_QR_BANK_ID=970422
BANK_QR_ACCOUNT_NO=0123456789
BANK_QR_ACCOUNT_NAME=NGUYEN VAN A
BANK_QR_TEMPLATE=compact2
BANK_QR_EXPIRE_MINUTES=15

# Token gắn trong header secure-token khi Casso/VietQR gọi webhook về backend
BANK_QR_WEBHOOK_SECURE_TOKEN=change-me

# payOS
PAYOS_CLIENT_ID=your-client-id
PAYOS_API_KEY=your-api-key
PAYOS_CHECKSUM_KEY=your-checksum-key
PAYOS_API_BASE_URL=https://api-merchant.payos.vn
PAYOS_RETURN_PATH=/payment/result
PAYOS_CANCEL_PATH=/payment/result
PAYOS_EXPIRE_MINUTES=15
